# Storefront → live backend / platform wiring
# Copy to .env.local for local development.

# .NET API base (Docker maps container 8080 -> host 5001 in dev)
NEXT_PUBLIC_API_URL=http://localhost:5001
# Where uploaded unit images are served from (usually same host as the API)
NEXT_PUBLIC_STORAGE_URL=http://localhost:5001
# The Kaza platform (rental-platform) that owns auth — storefront hands login off to it
NEXT_PUBLIC_PLATFORM_URL=http://localhost:3001
